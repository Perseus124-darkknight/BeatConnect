{
  "name": "chatbot-widget",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start:db": "cd ai-backend && docker-compose up -d db",
    "start:backend": "cd ai-backend && DB_PORT=3307 npm run dev",
    "start:frontend": "cd ai-frontend && npm run dev",
    "dev:all": "npm run start:db && npm run start:backend & npm run start:frontend",
    "test": "NODE_ENV=test jest --passWithNoTests"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "marked": "^17.0.5",
    "terser": "^5.36.0",
    "vite-tsconfig-paths": "^5.1.3",
    "yt-search": "^2.13.1"
  }
}
